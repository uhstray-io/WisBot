# ── Discord ─────────────────────────────────────────────────────────────────
# Bot token. Local dev can instead place it in a `discord.key` file at repo root.
# In deployment this is injected from the secrets store, never committed.
DISCORD_TOKEN_WISBOT=

# Guild (server) the bot serves — slash command registration target. REQUIRED.
WISBOT_GUILD_ID=000000000000000000

# /testrecord terminal command targets (optional; TEST_GUILD_ID defaults to WISBOT_GUILD_ID)
# WISBOT_TEST_GUILD_ID=000000000000000000
# WISBOT_TEST_VOICE_CHANNEL_ID=000000000000000000

# ── Persistence (point at mounted volumes in the container) ───────────────────
# SQLite database file path (default: wisbot.db)
# WISBOT_DB_PATH=/app/data/wisbot.db
# Directory for saved voice recordings (default: recordings)
# WISBOT_RECORDINGS_DIR=/app/recordings
# Days to keep saved WAV recordings before auto-deletion (default 30)
# WISBOT_RECORDINGS_RETENTION_DAYS=30
# Days to keep WisLLM conversation history before auto-deletion (default 30)
# WISLLM_HISTORY_RETENTION_DAYS=30
# Days to keep passive voice join/leave activity (feeds /voicestats) before auto-deletion (default 90)
# WISBOT_VOICE_ACTIVITY_RETENTION_DAYS=90
# Max pending reminders a single user may queue at once (default 25)
# WISBOT_REMINDER_MAX_PER_USER=25

# ── Health endpoint ───────────────────────────────────────────────────────────
# HTTP GET /health → 200 once connected, 503 while starting. Used by container/orchestration health checks.
# Host defaults to "localhost" (dev). In a container set it to "+" so Docker port mapping can reach it.
# WISBOT_HEALTH_HOST=+
# WISBOT_HEALTH_PORT=8080

# ── File relay (/upload) ──────────────────────────────────────────────────────
# Public base URL used to build upload/download links (the user opens this in a browser).
# In production this is the Caddy-fronted subdomain, e.g. https://up.uhstray.io
# WISBOT_PUBLIC_BASE_URL=http://localhost:8080
# Per-file size cap in bytes (default 104857600 = 100 MB)
# WISBOT_UPLOAD_MAX_BYTES=104857600
# Days to retain an uploaded file before auto-deletion (default 30)
# WISBOT_UPLOAD_RETENTION_DAYS=30
# Per-user abuse caps: max outstanding links and total stored bytes (default 20 / 2 GB)
# WISBOT_UPLOAD_MAX_LINKS_PER_USER=20
# WISBOT_UPLOAD_MAX_BYTES_PER_USER=2147483648
# Public upload-route requests per minute per client IP (default 30)
# WISBOT_UPLOAD_RATE_LIMIT_PER_MINUTE=30
# Max downloads before a link auto-expires (default 0 = unlimited until time expiry)
# WISBOT_UPLOAD_MAX_DOWNLOADS=0

# MinIO object storage (file bytes). Empty endpoint disables uploads.
# WISBOT_MINIO_ENDPOINT=minio:9000
# WISBOT_MINIO_ACCESS_KEY=
# WISBOT_MINIO_SECRET_KEY=
# WISBOT_MINIO_BUCKET=wisbot-uploads
# WISBOT_MINIO_USE_SSL=false

# ── Ollama / WisLLM ───────────────────────────────────────────────────────────
# Ollama LLM endpoint (IP or hostname of the machine running Ollama)
OLLAMA_ENDPOINT=http://192.168.1.x:11434

# Default model to use when none is specified in /wisllm ask
OLLAMA_DEFAULT_MODEL=llama3

# How many previous exchanges to include as context on each request (default: 10)
WISLLM_CONTEXT_LIMIT=10

# Warn the user (ephemeral) when estimated token usage exceeds this % of the model's context window (default: 75)
WISLLM_WARN_AT_PERCENT=75

# Hard-code the model's context window size in tokens.
# If set, skips the Ollama /api/show query. Leave unset to query Ollama dynamically.
# Common values: llama3=8192, mistral=8192, mixtral=32768, llama2=4096, default fallback=32768
# WISLLM_CONTEXT_SIZE=8192
