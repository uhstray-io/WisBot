<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Discord.Net" Version="3.19.0-beta.1" />
    <PackageReference Include="NAudio" Version="2.2.1" />
    <PackageReference Include="Concentus.Oggfile" Version="1.0.6" />
    <!-- Native libraries for Discord voice support -->
    <PackageReference Include="OpusDotNet.opus.win-x64" Version="1.3.1" />
    <PackageReference Include="libsodium" Version="1.0.20" />
    <!-- <PackageReference Include="System.Linq.Async" Version="7.0.0" ExcludeAssets="all" /> -->
    <!-- This is required for any thing Discord.Net 3.18 and below -->
  </ItemGroup>
</Project>
